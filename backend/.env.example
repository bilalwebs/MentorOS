# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.

# --- App ---
ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000

# --- Database ---
# Local dev default (SQLite, zero setup):
DATABASE_URL=sqlite:///./mentoros.db
# Production (PostgreSQL) example:
# DATABASE_URL=postgresql://user:password@host:5432/mentoros?sslmode=require

# --- Auth / JWT ---
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Qwen (OpenAI-compatible) ---
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# International endpoint: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024

# --- Vector Store ---
# "auto" detects from DATABASE_URL (pgvector for PostgreSQL, chroma for SQLite)
VECTOR_BACKEND=auto

# --- ChromaDB (local dev only) ---
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION_NAME=mentoros_memories

# --- Memory Engine tuning ---
MEMORY_DECAY_RATE=0.05
MEMORY_ARCHIVE_THRESHOLD=0.15
MEMORY_RETRIEVAL_TOP_K=8
