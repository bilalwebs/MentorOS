# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.

# --- App ---
ENV=development
DEBUG=true

# --- Database ---
# Local dev default (SQLite, zero setup):
DATABASE_URL=sqlite:///./mentoros.db
# Production (PostgreSQL) example — swap this in with no code changes:
# DATABASE_URL=postgresql+psycopg2://mentoros_user:password@localhost:5432/mentoros

# --- Auth / JWT ---
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Qwen (OpenAI-compatible) ---
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION_NAME=mentoros_memories

# --- Memory Engine tuning ---
MEMORY_DECAY_RATE=0.05
MEMORY_ARCHIVE_THRESHOLD=0.15
MEMORY_RETRIEVAL_TOP_K=8
